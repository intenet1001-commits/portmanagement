# Vercel 빌드 시 주입되는 환경변수 (로컬 개발에선 선택).
# `vercel env add <KEY>` 로 등록하거나 Vercel 대시보드의 Environment Variables 에 추가.

# Supabase 프로젝트 URL — https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase anon public key — supabase 대시보드 → Project Settings → API
VITE_SUPABASE_ANON_KEY=

# 포털 비밀번호의 SHA-256 해시(선택). 빈 문자열이면 공개 포털.
# 해시 생성: `printf "mypassword" | shasum -a 256`
VITE_PORTAL_PASSWORD_HASH=

# (선택) api-server 에서 사용할 포크된 GitHub 정보.
# 미설정 시 원본 저장소가 사용됩니다.
PORTMGR_GITHUB_OWNER=
PORTMGR_GITHUB_REPO=
PORTMGR_GITHUB_WORKFLOW=

# (선택) SetupWizard의 git clone / Fork 링크가 가리킬 저장소.
# 미설정 시 원본(intenet1001-commits/portmanagement)을 사용합니다.
VITE_REPO_URL=
