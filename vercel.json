{
  "buildCommand": "npx vite build --config vite.portal.config.ts",
  "outputDirectory": "dist-portal",
  "rewrites": [
    { "source": "/setup", "destination": "/setup.html" },
    { "source": "/(.*)", "destination": "/portal.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https: 'unsafe-inline' 'unsafe-eval'; frame-ancestors 'none'" }
      ]
    }
  ]
}
