  ],
  "sections": [
    {
      "tab": "ports",
      "id": "header",
      "title": "헤더 — 프로젝트 관리 프로그램",
      "description": "앱 제목, 주요 액션 버튼 행 (AI이름 프롬프트, 내보내기, 불러오기, 새로고침, Supabase Push/Pull), 웹 모드 전용 빌드 버튼 행"
    },
    {
      "tab": "ports",
      "id": "add-form",
      "title": "포트 추가 폼",
      "description": "새 프로젝트를 등록하는 인라인 폼 (이름, 포트, command 경로, 터미널 명령어, 폴더 경로, 배포 URL, GitHub URL, 카테고리, 설명)"
    },
    {
      "tab": "ports",
      "id": "workspace-roots",
      "title": "작업 루트",
      "description": "워크스페이스 루트 폴더 목록. 루트 추가 버튼, 각 루트마다 '새 프로젝트' 및 삭제 버튼"
    },
    {
      "tab": "ports",
      "id": "port-list",
      "title": "포트 목록",
      "description": "등록된 포트/프로젝트 카드 목록. 검색, 필터(all/with-port/without-port), 카테고리 필터, 정렬(최근/이름/포트 + asc/desc), bypass permissions 토글 포함"
    },
    {
      "tab": "portal",
      "id": "portal-sidebar",
      "title": "포털 카테고리 사이드바",
      "description": "전체/카테고리별 필터. 카테고리 추가 버튼. 각 카테고리 삭제 버튼"
    },
    {
      "tab": "portal",
      "id": "portal-main",
      "title": "포털 메인 콘텐츠",
      "description": "검색바, 아이템 추가 버튼, Supabase Push/Pull, 내보내기/불러오기, 설정 버튼. 핀고정/비핀고정 아이템 카드 목록"
    }
  ],
  "forms": [
    {
      "id": "add-port-form",
      "tab": "ports",
      "section": "add-form",
      "fields": [
        { "type": "text", "placeholder": "프로젝트 이름", "stateVar": "name", "required": true },
        { "type": "number", "placeholder": "포트", "stateVar": "port", "required": true },
        { "type": "text", "placeholder": ".command / .html 파일 경로 (선택사항)", "stateVar": "commandPath" },
        { "type": "text", "placeholder": "터미널 명령어 (선택사항, 예: bunx cursor-talk-to-figma-socket)", "stateVar": "terminalCommand" },
        { "type": "text", "placeholder": "프로젝트 폴더 경로 (선택사항)", "stateVar": "folderPath" },
        { "type": "text", "placeholder": "배포 사이트 주소 (선택사항, 예: https://example.com)", "stateVar": "deployUrl" },
        { "type": "text", "placeholder": "GitHub 주소 (선택사항, 예: https://github.com/user/repo)", "stateVar": "githubUrl" },
        { "type": "select", "placeholder": "카테고리 (선택사항)", "stateVar": "category", "options": ["frontend", "backend", "AI", "tools", "infra", "mobile", "data", "fullstack"] },
        { "type": "text", "placeholder": "프로젝트 설명 (선택사항)", "stateVar": "description" }
      ],
      "submitButton": "추가 (addPort)"
    },
    {
      "id": "edit-port-form",
      "tab": "ports",
      "section": "port-list",
      "description": "인라인 수정 폼 (editingId !== null일 때). 필드 구성은 add-port-form과 동일",
      "fields": [
        { "type": "text", "stateVar": "editName", "placeholder": "프로젝트 이름" },
        { "type": "number", "stateVar": "editPort", "placeholder": "포트" },
        { "type": "text", "stateVar": "editCommandPath" },
        { "type": "text", "stateVar": "editTerminalCommand" },
        { "type": "text", "stateVar": "editFolderPath" },
        { "type": "text", "stateVar": "editDeployUrl" },
        { "type": "text", "stateVar": "editGithubUrl" },
        { "type": "select", "stateVar": "editCategory", "options": ["frontend", "backend", "AI", "tools", "infra", "mobile", "data", "fullstack"] },
        { "type": "text", "stateVar": "editDescription" }
      ],
      "submitButton": "저장 (saveEdit, Check icon)",
      "cancelButton": "취소 (cancelEdit, X icon)"
    },
    {
      "id": "new-project-modal-form",
      "tab": "ports",
      "section": "workspace-roots",
      "description": "새 프로젝트 폴더 생성 모달 (showNewProjectModal = true)",
      "fields": [
        { "type": "text", "stateVar": "newProjectName", "placeholder": "프로젝트 폴더 이름", "autoFocus": true },
        { "type": "checkbox", "stateVar": "registerAsProject", "label": "포트 목록에 프로젝트로 등록" }
      ],
      "submitButton": "생성 (handleCreateProjectFolder)",
      "cancelButton": "취소 (setShowNewProjectModal(false))"
    },
    {
      "id": "portal-add-item-form",
      "tab": "portal",
      "description": "포털 아이템 추가/편집 모달",
      "fields": [
        { "type": "radio-buttons", "stateVar": "form.type", "options": ["link", "folder", "command"] },
        { "type": "text", "stateVar": "form.name", "placeholder": "이름" },
        { "type": "text", "stateVar": "form.url", "placeholder": "URL / 경로" },
        { "type": "text", "stateVar": "form.description", "placeholder": "설명" },
        { "type": "checkbox", "stateVar": "form.pinned", "label": "핀 고정" }
      ]
    },
    {
      "id": "portal-category-form",
      "tab": "portal",
      "description": "카테고리 추가 모달 (showCatModal = true)",
      "fields": [
        { "type": "text", "stateVar": "catForm.name", "placeholder": "카테고리 이름" },
        { "type": "color-picker", "stateVar": "catForm.color", "options": ["blue", "green", "yellow", "red", "purple", "pink", "indigo", "orange", "teal", "gray"] }
      ]
    },
    {
      "id": "portal-search",
      "tab": "portal",
      "fields": [
        { "type": "text", "stateVar": "search", "placeholder": "검색..." }
      ]
    },
    {
      "id": "port-list-search",
      "tab": "ports",
      "fields": [
        { "type": "text", "stateVar": "searchQuery", "placeholder": "프로젝트 검색..." }
      ]
    }
  ],
  "buttons": [
    {
      "label": "프로젝트 관리",
