      "location": "tab-nav",
      "icon": "BookMarked"
    },
    {
      "label": "AI이름 프롬프트",
      "action": "handleCopyAiNamePrompt",
      "location": "header",
      "tab": "ports",
      "color": "emerald",
      "icon": "Sparkles",
      "title": "Claude Code에 붙여넣을 AI이름 생성 프롬프트를 클립보드에 복사"
    },
    {
      "label": "내보내기",
      "action": "handleExportPorts",
      "location": "header",
