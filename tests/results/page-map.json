      "icon": "X"
    },
    {
      "label": "추가 (포털 아이템)",
      "action": "openAddModal",
      "location": "portal-topbar",
      "tab": "portal",
      "color": "blue",
      "icon": "Plus"
    },
    {
      "label": "Push (포털)",
      "action": "syncSupabase",
      "location": "portal-topbar",
      "tab": "portal",
      "icon": "CloudUpload",
      "disabledWhen": "isSyncing"
    },
    {
      "label": "Pull (포털)",
      "action": "pullFromSupabase",
      "location": "portal-topbar",
      "tab": "portal",
      "icon": "CloudDownload",
      "disabledWhen": "isRestoring"
    },
    {
      "label": "내보내기 (포털)",
      "action": "exportData",
      "location": "portal-topbar",
      "tab": "portal",
      "icon": "Download"
    },
    {
      "label": "불러오기 (포털)",
      "action": "importData",
      "location": "portal-topbar",
      "tab": "portal",
      "icon": "Upload"
    },
    {
      "label": "설정 (포털)",
      "action": "setShowSettings(true)",
      "location": "portal-topbar",
      "tab": "portal",
      "icon": "Settings"
    },
    {
      "label": "전체",
      "action": "setSelectedCat('all')",
      "location": "portal-sidebar",
      "tab": "portal",
      "icon": "BookMarked"
    },
    {
      "label": "카테고리 추가",
      "action": "setShowCatModal(true)",
      "location": "portal-sidebar",
      "tab": "portal",
      "icon": "Plus"
    },
    {
      "label": "카테고리 삭제",
      "action": "deleteCategory(cat.id)",
      "location": "portal-sidebar-item",
      "tab": "portal",
      "icon": "X",
      "perItem": true
    }
  ],
  "modals": [
    {
      "id": "build-log-modal",
      "trigger": "handleBuildApp / handleBuildDmg / handleBuildWindows",
      "stateVar": "showBuildLog",
      "title": "{buildType} 빌드 진행 상황",
      "description": "실시간 빌드 로그 표시. 색상 코딩: 빨강(에러), 초록(성공), 노랑(경고). 로그 복사 버튼 포함"
    },
    {
      "id": "worktree-picker-modal",
      "trigger": "executeCommand (tmux/claude mode with git worktrees)",
      "stateVar": "worktreePickerState",
      "title": "Git 워크트리 선택",
      "description": "감지된 워크트리 목록 표시. 워크트리 없이 실행 / 실행 → 버튼"
    },
    {
      "id": "new-project-modal",
      "trigger": "작업 루트 → 새 프로젝트 버튼",
      "stateVar": "showNewProjectModal",
      "title": "새 프로젝트 생성",
      "description": "프로젝트 이름 입력 + 포트 목록 등록 체크박스. Enter 키로 제출 가능"
    },
    {
      "id": "portal-add-item-modal",
      "trigger": "포털 → 추가 버튼",
      "stateVar": "showAddModal (PortalManager)",
      "description": "포털 아이템 추가/편집 (name, type, url/path, description, pinned)"
    },
    {
      "id": "portal-category-modal",
      "trigger": "포털 사이드바 → 카테고리 추가",
      "stateVar": "showCatModal (PortalManager)",
      "description": "카테고리 이름 + 색상 선택 (blue/green/yellow/red/purple/pink/indigo/orange/teal/gray)"
    },
    {
      "id": "portal-settings-modal",
      "trigger": "포털 → 설정 버튼",
      "stateVar": "showSettings (PortalManager)",
      "description": "Supabase URL + anon key 입력. SetupGuide (DDL 프롬프트 복사 아코디언) 포함"
    }
  ],
  "features": {
    "hasSPARouter": false,
    "hasInfiniteScroll": false,
    "hasLazyLoading": false,
    "hasAuth": false,
