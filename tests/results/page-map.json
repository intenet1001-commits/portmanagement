    {
      "label": "DMG 출시하기",
      "action": "handleExportDmg",
      "location": "header-row2",
      "tab": "ports",
      "condition": "!isTauri()",
      "color": "blue",
      "icon": "Rocket"
    },
    {
      "label": "Windows 빌드",
      "action": "handleBuildWindows",
      "location": "header-row2",
      "tab": "ports",
      "condition": "!isTauri()",
      "color": "indigo",
      "icon": "Monitor",
      "disabledWhen": "isBuilding"
    },
    {
      "label": "추가",
      "action": "addPort",
      "location": "add-form",
      "tab": "ports",
      "color": "blue",
      "icon": "Plus"
    },
    {
      "label": "루트 추가",
      "action": "handleAddWorkspaceRoot",
      "location": "workspace-roots",
      "tab": "ports",
      "icon": "Plus"
    },
    {
      "label": "새 프로젝트",
      "action": "setShowNewProjectModal(true)",
      "location": "workspace-roots-item",
      "tab": "ports",
      "color": "green",
      "icon": "FilePlus",
      "perItem": true
    },
    {
      "label": "삭제 (루트)",
      "action": "handleRemoveWorkspaceRoot(root.id)",
      "location": "workspace-roots-item",
      "tab": "ports",
      "color": "red",
      "perItem": true
    },
    {
      "label": "검색 초기화",
      "action": "setSearchQuery('')",
      "location": "port-list-search",
      "tab": "ports",
      "icon": "X",
      "condition": "searchQuery !== ''"
    },
    {
      "label": "bypass permissions",
      "action": "setBypassPermissions(v => !v)",
      "location": "port-list-toolbar",
      "tab": "ports",
      "toggle": true,
      "color": "orange (active) / zinc (inactive)"
    },
    {
      "label": "정렬 방향 토글 (↑오름 / ↓내림)",
      "action": "setSortOrder",
      "location": "port-list-toolbar",
      "tab": "ports"
    },
    {
      "label": "새로고침 (포트 상태)",
      "action": "handleRefresh",
      "location": "port-list-toolbar",
      "tab": "ports",
      "icon": "RefreshCw"
    },
    {
      "label": "열기 (HTML 파일)",
      "action": "executeCommand(item)",
      "location": "port-card",
      "tab": "ports",
      "condition": "isHtmlFile(item.commandPath)",
      "color": "blue",
      "icon": "ExternalLink",
      "perItem": true
    },
    {
      "label": "중지",
      "action": "stopCommand(item)",
      "location": "port-card",
      "tab": "ports",
      "condition": "item.isRunning",
      "color": "red",
      "icon": "Square",
      "perItem": true
    },
    {
      "label": "강제재실행",
      "action": "forceRestartCommand(item)",
      "location": "port-card",
      "tab": "ports",
      "color": "orange",
      "icon": "RotateCw",
      "perItem": true
    },
    {
      "label": "실행",
      "action": "executeCommand(item)",
      "location": "port-card",
      "tab": "ports",
      "condition": "!item.isRunning",
      "color": "green",
      "icon": "Play",
      "perItem": true
    },
    {
      "label": "로그",
      "action": "API.openLog(item.id)",
      "location": "port-card",
      "tab": "ports",
      "condition": "isTauri() && (item.commandPath || item.terminalCommand)",
      "color": "amber",
      "icon": "FileText",
      "perItem": true
    },
    {
      "label": "tmux",
      "action": "openTmuxClaude(item)",
      "location": "port-card",
      "tab": "ports",
      "color": "violet (normal) / orange (bypass)",
      "icon": "SquareTerminal",
      "perItem": true
    },
    {
      "label": "↺ (tmux 새로 열기)",
      "action": "openTmuxClaudeFresh(item)",
      "location": "port-card",
      "tab": "ports",
      "color": "violet (normal) / orange (bypass)",
      "perItem": true
    },
    {
      "label": "Claude",
      "action": "openTerminalClaude(item)",
      "location": "port-card",
      "tab": "ports",
      "color": "indigo (normal) / orange (bypass)",
      "icon": "Terminal",
      "perItem": true
    },
    {
      "label": "폴더",
      "action": "API.openFolder(item.folderPath)",
      "location": "port-card",
      "tab": "ports",
      "condition": "item.folderPath",
      "color": "zinc",
      "icon": "Folder",
      "perItem": true
    },
    {
      "label": "배포",
      "action": "API.openInChrome(item.deployUrl) or <a> link",
      "location": "port-card",
      "tab": "ports",
      "condition": "item.deployUrl",
      "color": "purple",
      "icon": "Globe",
      "perItem": true
    },
    {
      "label": "GitHub",
      "action": "API.openInChrome(item.githubUrl) or <a> link",
      "location": "port-card",
      "tab": "ports",
      "condition": "item.githubUrl",
      "color": "zinc",
      "icon": "Github",
      "perItem": true
    },
    {
      "label": "수정",
      "action": "setEditingId(item.id)",
      "location": "port-card",
      "tab": "ports",
      "icon": "Pencil",
      "perItem": true
    },
    {
      "label": "삭제",
      "action": "deletePort(item.id)",
      "location": "port-card",
      "tab": "ports",
      "icon": "Trash2",
      "color": "red",
      "perItem": true
    },
    {
      "label": "저장 (수정)",
      "action": "saveEdit",
      "location": "port-card-edit",
      "tab": "ports",
      "icon": "Check",
      "color": "green"
    },
    {
      "label": "취소 (수정)",
      "action": "cancelEdit",
      "location": "port-card-edit",
      "tab": "ports",
      "icon": "X"
    },
    {
      "label": "로그 복사",
